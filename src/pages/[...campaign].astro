---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Benefits from '../components/Benefits.astro';
import SocialProof from '../components/SocialProof.astro';
import FAQ from '../components/FAQ.astro';
import CTABottom from '../components/CTABottom.astro';
import LeadForm from '../components/LeadForm.astro';
import { loadCampaignContent, loadCampaignConfig } from '../lib/content-loader';

const { campaign } = Astro.params;
let content: ReturnType<typeof loadCampaignContent> = null;
let config: ReturnType<typeof loadCampaignConfig> = null;
let loadError = '';

try {
  content = loadCampaignContent(campaign as string);
  config = loadCampaignConfig(campaign as string);
} catch (e: unknown) {
  loadError = e instanceof Error ? e.message : String(e);
}

if (!content || !config) {
  return new Response(`Campaign not found: ${campaign}. Error: ${loadError}`, { status: 404 });
}

const activeExperiment = config.experiments?.find(e => e.status === 'active');
---

<BaseLayout
  title={content.hero.headline}
  description={content.hero.subhead}
  canonicalUrl={config.seo?.canonical || `https://landing.protocol.us/${config.slug}`}
  noindex={config.seo?.index === true ? false : true}
>
  <Hero headline={content.hero.headline} subhead={content.hero.subhead} cta_label={content.hero.cta_label} cta_url={content.hero.cta_url} background={content.hero.background || 'dark'} />

  {content.benefits && content.benefits.items && <Benefits title={content.benefits.title} items={content.benefits.items} layout={content.benefits.layout} />}

  {content.bodyHtml && (
    <section class="body-content">
      <div class="body-inner" set:html={content.bodyHtml} />
    </section>
  )}

  {content.social_proof && Array.isArray(content.social_proof) && content.social_proof.length > 0 && <SocialProof items={content.social_proof} />}

  <LeadForm
    campaignSlug={config.slug}
    variantId={activeExperiment?.variant || 'v1'}
    offerType={config.offer?.type || ''}
    ctaLabel={content.hero.cta_label}
  />

  {content.faq && Array.isArray(content.faq) && <FAQ items={content.faq} />}

  {content.cta_bottom && content.cta_bottom.headline && <CTABottom headline={content.cta_bottom.headline} body={content.cta_bottom.body} cta_label={content.cta_bottom.cta_label} cta_url={content.cta_bottom.cta_url} />}
</BaseLayout>
