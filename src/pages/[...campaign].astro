---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Benefits from '../components/Benefits.astro';
import SocialProof from '../components/SocialProof.astro';
import FAQ from '../components/FAQ.astro';
import CTABottom from '../components/CTABottom.astro';
import LeadForm from '../components/LeadForm.astro';
import GHLFormModal from '../components/GHLFormModal.astro';
import Timeline from '../components/Timeline.astro';
import EvidenceBlock from '../components/EvidenceBlock.astro';
import { loadCampaignContent, loadCampaignConfig } from '../lib/content-loader';

const { campaign } = Astro.params;
const content = loadCampaignContent(campaign as string);
const config = loadCampaignConfig(campaign as string);

if (!content || !config) {
  return Astro.redirect('/');
}

const activeExperiment = config.experiments?.find(e => e.status === 'active');
const pageTheme = config.theme || 'dark';
const useGHLModal = config.cta?.type === 'ghl_modal';
---

<BaseLayout
  title={content.hero.headline}
  description={content.hero.subhead}
  canonicalUrl={config.seo?.canonical || `https://landing.protocol.us/${config.slug}`}
  noindex={config.seo?.index === true ? false : true}
  theme={pageTheme}
>
  <Hero {...content.hero} theme={content.hero.theme || pageTheme} />

  {content.benefits && (
    <Benefits {...content.benefits} theme={content.benefits.theme || pageTheme} />
  )}

  {content.bodyHtml && (
    <section class="body-content" data-theme={pageTheme}>
      <div class="body-inner section-inner" set:html={content.bodyHtml} />
    </section>
  )}

  {content.social_proof && (
    <SocialProof {...content.social_proof} theme={content.social_proof.theme || pageTheme} />
  )}

  {content.timeline && (
    <Timeline {...content.timeline} theme={content.timeline.theme || pageTheme} />
  )}

  {useGHLModal ? (
    <GHLFormModal
      formUrl={config.cta?.form_url}
      bookingUrl={config.cta?.booking_url}
      formName={`Protocol Form - ${config.slug}`}
      theme={pageTheme}
    />
  ) : (
    <LeadForm
      campaignSlug={config.slug}
      variantId={activeExperiment?.variant || 'v1'}
      offerType={config.offer?.type || ''}
      ctaLabel={content.hero.cta_label}
      theme={pageTheme}
    />
  )}

  {content.faq && (
    <FAQ {...content.faq} theme={content.faq.theme || pageTheme} />
  )}

  {content.evidence && (
    <EvidenceBlock {...content.evidence} theme={content.evidence.theme || pageTheme} />
  )}

  {content.cta_bottom && (
    <CTABottom {...content.cta_bottom} theme={content.cta_bottom.theme || pageTheme} />
  )}
</BaseLayout>
