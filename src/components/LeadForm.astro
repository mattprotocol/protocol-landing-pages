---
interface Props {
  campaignSlug: string;
  variantId?: string;
  offerType?: string;
  ctaLabel?: string;
  theme?: 'dark' | 'light';
  title?: string;
  subtitle?: string;
}

const {
  campaignSlug,
  variantId = 'v1',
  offerType = '',
  ctaLabel = 'Get Started',
  theme = 'dark',
  title = 'Take the first step.',
  subtitle = 'Tell us about yourself and a Protocol team member will reach out.'
} = Astro.props;
const metaPixelId = (import.meta.env.META_PIXEL_ID || '').trim();
const googleAdsId = (import.meta.env.GOOGLE_ADS_ID || '').trim();
const googleAdsConversionLabel = (import.meta.env.GOOGLE_ADS_CONVERSION_LABEL || '').trim();
---

<section class="lead-form-section" id="lead-form" data-theme={theme}>
  <div class="lead-form-inner reveal">
    <h2 class="section-heading center">{title}</h2>
    <p class="lead-form-subtitle">{subtitle}</p>

    <form id="protocol-lead-form" class="lead-form" data-campaign={campaignSlug} data-variant={variantId} data-offer={offerType}>
      <div class="form-row">
        <input class="form-input" type="text" name="firstName" placeholder="First name" required autocomplete="given-name" />
        <input class="form-input" type="text" name="lastName" placeholder="Last name" required autocomplete="family-name" />
      </div>
      <input class="form-input" type="email" name="email" placeholder="Email address" required autocomplete="email" />
      <input class="form-input" type="tel" name="phone" placeholder="Phone number (optional)" autocomplete="tel" />
      <button type="submit" class="cta-btn form-submit" id="form-submit-btn">{ctaLabel}</button>
      <p class="form-trust">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Your information is private and secure. No spam, ever.
      </p>
      <div class="form-status" id="form-status" aria-live="polite"></div>
    </form>
  </div>
</section>

<script define:vars={{ campaignSlug, variantId, offerType, ctaLabel, metaPixelId, googleAdsId, googleAdsConversionLabel }}>
  function uuidv4() {
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      const r = Math.random() * 16 | 0;
      return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
    });
  }

  const form = document.getElementById('protocol-lead-form');
  const submitBtn = document.getElementById('form-submit-btn');
  const statusEl = document.getElementById('form-status');

  // Track form_start on first input focus
  let formStarted = false;
  form.querySelectorAll('input').forEach(input => {
    input.addEventListener('focus', () => {
      if (!formStarted) {
        formStarted = true;
        if (window.gtag) gtag('event', 'form_start', { campaign: campaignSlug });
      }
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Dedup: prevent double-submit
    const existingRequestId = sessionStorage.getItem(`submitted_${campaignSlug}`);
    if (existingRequestId) {
      statusEl.textContent = 'You have already submitted this form.';
      statusEl.className = 'form-status info';
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    const requestId = uuidv4();
    const eventId = uuidv4();
    const utmData = JSON.parse(sessionStorage.getItem('utm_data') || '{}');
    const formData = new FormData(form);

    // Combine first + last name for backward compatibility with API
    const firstName = formData.get('firstName') || '';
    const lastName = formData.get('lastName') || '';
    const fullName = `${firstName} ${lastName}`.trim();

    const payload = {
      request_id: requestId,
      event_id: eventId,
      campaign_slug: campaignSlug,
      variant_id: variantId,
      offer_type: offerType,
      name: fullName,
      email: formData.get('email'),
      phone: formData.get('phone') || '',
      page_url: window.location.href,
      referrer: document.referrer,
      ...utmData
    };

    // Fire gtag form_submit BEFORE the fetch call
    if (window.gtag) {
      gtag('event', 'form_submit', {
        campaign: campaignSlug,
        variant: variantId
      });
    }

    try {
      const res = await fetch('/api/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const result = await res.json();

      if (result.success) {
        sessionStorage.setItem(`submitted_${campaignSlug}`, requestId);

        statusEl.textContent = "Thank you! We'll be in touch within one business day.";
        statusEl.className = 'form-status success';
        form.querySelector('.form-row').style.display = 'none';
        form.querySelectorAll('.form-input').forEach(el => el.style.display = 'none');
        submitBtn.style.display = 'none';
        form.querySelector('.form-trust').style.display = 'none';

        // GA4 lead event
        if (window.gtag) {
          gtag('event', 'generate_lead', {
            campaign: campaignSlug,
            variant: variantId,
            value: 0,
            currency: 'USD'
          });
        }

        // Meta Pixel Lead (with event_id for CAPI dedup)
        if (window.fbq && metaPixelId) {
          fbq('track', 'Lead', {}, { eventID: eventId });
        }

        // Google Ads conversion
        if (window.gtag && googleAdsId && googleAdsConversionLabel) {
          gtag('event', 'conversion', {
            send_to: `${googleAdsId}/${googleAdsConversionLabel}`,
            event_callback: function() {}
          });
        }
      } else {
        throw new Error(result.error || 'Submission failed');
      }
    } catch (err) {
      statusEl.textContent = 'Something went wrong. Please try again.';
      statusEl.className = 'form-status error';
      submitBtn.disabled = false;
      submitBtn.textContent = ctaLabel || 'Get Started';
      console.error('Form submission error:', err);
    }
  });
</script>
