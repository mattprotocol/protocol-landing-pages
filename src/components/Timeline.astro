---
interface TimelineItem {
  number: string;
  title: string;
  body: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  theme?: 'dark' | 'light';
  items: TimelineItem[];
  footnote?: string;
  cta_label?: string;
  cta_url?: string;
}

const { eyebrow, title, theme = 'dark', items, footnote, cta_label, cta_url } = Astro.props;
---

<section class="timeline-section" data-theme={theme}>
  <div class="section-inner">
    <div class="reveal">
      {eyebrow && <div class="section-tag center">{eyebrow}</div>}
      <h2 class="section-heading center">{title}</h2>
    </div>

    <div class="timeline reveal">
      {items.map((item, i) => (
        <div class="timeline-item">
          <div class="timeline-spine">
            <div class="timeline-badge">{item.number}</div>
            {i < items.length - 1 && <div class="timeline-connector"></div>}
          </div>
          <div class="timeline-content">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </div>
      ))}
    </div>

    {footnote && <p class="timeline-footnote reveal">{footnote}</p>}

    {cta_label && cta_url && (
      <div class="timeline-cta reveal" style="text-align: center; margin-top: 48px;">
        <a href={cta_url} class="cta-btn">{cta_label}</a>
      </div>
    )}
  </div>
</section>
